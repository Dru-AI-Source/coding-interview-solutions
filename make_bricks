def make_bricks(small, big, goal):
    # Use as many big bricks as possible without exceeding goal
    max_big = min(goal // 5, big)  
    
    # Remaining space that needs to be filled with small bricks
    remaining = goal % 5  # This directly gives the remainder after using big bricks
    
    return remaining <= small  # True if we have enough small bricks

